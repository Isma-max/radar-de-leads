# ─────────────────────────────────────────────────────────────
# Supabase
# Proyecto > Project Settings > API
# ─────────────────────────────────────────────────────────────
# URL del proyecto (pública)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# anon/public key (pública, usada en el navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# service_role key (SECRETA — solo servidor, nunca exponer en el cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─────────────────────────────────────────────────────────────
# Google Gemini (generación de texto)
# https://aistudio.google.com/
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...
# Modelo a usar (por defecto gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────────────────────
# Seguridad del job de importación (opcional)
# Si lo defines, /api/import exige el header  x-cron-secret: <valor>
# Útil para cron de Vercel.
# ─────────────────────────────────────────────────────────────
CRON_SECRET=
